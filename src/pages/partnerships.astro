---
// Partnerships (/partnerships) — REQ-1.4, REQ-5.3
import BaseLayout from '../layouts/BaseLayout.astro';

const strategicPartners = [
  {
    name: 'Blind Veterans UK',
    description: 'Supporting veterans with sight loss, providing rehabilitation, training and lifelong support.',
    funded: false,
    website: 'https://www.blindveterans.org.uk',
    need_tags: ['health', 'welfare'],
  },
  {
    name: 'Combat Stress',
    description: 'UK\'s leading charity for veterans\' mental health, providing specialist treatment and support.',
    funded: false,
    website: 'https://www.combatstress.org.uk',
    need_tags: ['mental_wellbeing'],
  },
  {
    name: 'Defence Medical Welfare Service',
    description: 'Welfare support for serving personnel and veterans in hospital and during recovery.',
    funded: false,
    website: 'https://www.dmws.org.uk',
    need_tags: ['health', 'welfare'],
  },
  {
    name: 'SSAFA',
    description: 'Armed forces charity providing lifelong practical, emotional and financial support to veterans and their families.',
    funded: false,
    website: 'https://www.ssafa.org.uk',
    need_tags: ['welfare', 'financial', 'housing'],
  },
  {
    name: 'Forces Employment Charity',
    description: 'Helping veterans, serving personnel and their families find meaningful employment.',
    funded: false,
    website: 'https://www.forcesemployment.org.uk',
    need_tags: ['employment'],
  },
  {
    name: 'Samaritans',
    description: 'Confidential emotional support for people experiencing distress or despair, available 24/7.',
    funded: false,
    website: 'https://www.samaritans.org',
    need_tags: ['mental_wellbeing'],
  },
  {
    name: 'The Royal British Legion',
    description: 'The UK\'s largest armed forces charity, providing welfare and support to veterans and their families.',
    funded: false,
    website: 'https://www.britishlegion.org.uk',
    need_tags: ['welfare', 'financial', 'health'],
  },
  {
    name: 'Veterans UK Welfare Service',
    description: 'Government welfare service providing support and information to veterans and their families.',
    funded: false,
    website: 'https://www.gov.uk/veterans-uk',
    need_tags: ['welfare', 'financial'],
  },
];

const communityPartners = [
  {
    name: 'West Indian Association of Service Personnel (WASP)',
    description: 'Preserving the legacy, welfare and recognition of Caribbean and African service personnel and veterans.',
    funded: true,
    website: 'https://www.wasp.org.uk',
    need_tags: ['welfare', 'heritage', 'mental_wellbeing'],
  },
  {
    name: 'Friends of Windrush Square',
    description: 'Supporting remembrance, heritage, Windrush education and community cohesion.',
    funded: false,
    website: '#TODO[CONFIRM]',
    need_tags: ['heritage', 'welfare'],
  },
  {
    name: 'Windrush Foundation',
    description: 'Safeguarding and advancing the education and welfare of people of Caribbean heritage in the UK.',
    funded: false,
    website: '#TODO[CONFIRM]',
    need_tags: ['heritage', 'welfare'],
  },
];

// Combined list for filter logic
const partners = [...strategicPartners, ...communityPartners];

const allTags = [
  { value: '',            label: 'All areas' },
  { value: 'health',     label: 'Health & Wellbeing' },
  { value: 'housing',    label: 'Housing' },
  { value: 'employment', label: 'Employment & Skills' },
  { value: 'financial',  label: 'Financial Guidance' },
  { value: 'welfare',    label: 'Welfare & Social Isolation' },
  { value: 'mental_wellbeing', label: 'Mental Wellbeing' },
  { value: 'heritage',   label: 'Heritage' },
];
---

<BaseLayout
  title="Partnerships"
  description="CivDivCIC partners with WASP, Windrush Foundation, Building Heroes and other organisations to deliver No Wrong Door support for veterans."
>

  <!-- Hero -->
  <section class="bg-brand-black section-padding py-14 md:py-20" aria-labelledby="partnerships-heading">
    <div class="container-max max-w-3xl">
      <h1 id="partnerships-heading" class="font-heading font-800 text-white heading-rule mb-6">Our Partnerships</h1>
      <p class="text-white/70 text-lg leading-relaxed max-w-2xl">
        No single organisation can meet every veteran's need. Our strength is the network we build — connecting veterans to the right specialist partner, every time.
      </p>
    </div>
  </section>

  <!-- Filter controls -->
  <section class="bg-warm-surface border-b border-black/10 py-5 px-4 md:px-8" aria-label="Filter partners by area">
    <div class="container-max">
      <div class="flex flex-wrap gap-2 items-center">
        <span class="text-sm font-600 text-black/60 mr-2">Filter by area:</span>
        {allTags.map(tag => (
          <button
            type="button"
            data-filter={tag.value}
            class:list={[
              'filter-btn px-4 py-2 rounded-full text-sm font-500 border transition-all',
              tag.value === '' ? 'bg-gold border-gold text-brand-black' : 'border-black/20 text-black/70 hover:border-gold/50 bg-white',
            ]}
            aria-pressed={tag.value === '' ? 'true' : 'false'}
          >
            {tag.label}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Partner directory -->
  <section class="section-white section-padding" aria-labelledby="partner-directory-heading">
    <div class="container-max">
      <h2 id="partner-directory-heading" class="sr-only">Partner directory</h2>

      <!-- Strategic Support & Pathway Partners -->
      <div class="mb-12">
        <h3 class="font-heading font-700 text-brand-black text-h3-mobile md:text-h3-desktop mb-3">Strategic Support &amp; Pathway Partners</h3>
        <p class="text-black/60 mb-6 max-w-2xl text-sm leading-relaxed">
          At CivDivCIC, we work alongside respected organisations that provide welfare, health, wellbeing, employment, advocacy and community support. Through partnership and signposting, we help veterans access the services they need — when they need them.
        </p>
        <div id="partner-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-4">
          {strategicPartners.map((p, i) => (
            <div
              class="card reveal partner-card"
              data-tags={p.need_tags.join(' ')}
              data-funded={String(p.funded)}
              style={`transition-delay: ${i * 60}ms`}
            >
              <div class="flex items-start justify-between gap-2 mb-3">
                <h4 class="font-heading font-600 text-brand-black text-sm leading-snug">{p.name}</h4>
                <span class="text-[10px] font-600 uppercase tracking-wider px-2 py-1 rounded-full flex-shrink-0 bg-black/5 text-black/40">
                  Unfunded
                </span>
              </div>
              <p class="text-black/60 text-xs leading-relaxed flex-1 mb-3">{p.description}</p>
              <div class="flex flex-wrap gap-1 mb-3">
                {p.need_tags.map(tag => (
                  <span class="text-[10px] bg-warm-surface border border-black/[0.08] text-black/50 px-2 py-0.5 rounded-full capitalize">
                    {tag.replace('_', ' ')}
                  </span>
                ))}
              </div>
              {p.website && !p.website.startsWith('#') ? (
                <a
                  href={p.website}
                  class="text-gold-dark text-xs font-500 no-underline hover:underline inline-flex items-center gap-1 mt-auto"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Visit website
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
              ) : (
                <span class="text-black/30 text-[10px] italic mt-auto">Website — TODO[CONFIRM]</span>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Community & Heritage Partners -->
      <div class="mb-8">
        <h3 class="font-heading font-700 text-brand-black text-h3-mobile md:text-h3-desktop mb-3">Community &amp; Heritage Partners</h3>
        <p class="text-black/60 mb-6 max-w-2xl text-sm leading-relaxed">
          Our community and heritage partners help preserve military history, celebrate service, and strengthen community identity through remembrance, education and cultural engagement.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {communityPartners.map((p, i) => (
            <div
              class="card reveal partner-card"
              data-tags={p.need_tags.join(' ')}
              data-funded={String(p.funded)}
              style={`transition-delay: ${i * 75}ms`}
            >
              <div class="flex items-start justify-between gap-2 mb-3">
                <h4 class="font-heading font-600 text-brand-black text-sm leading-snug">{p.name}</h4>
                <span class:list={[
                  'text-[10px] font-600 uppercase tracking-wider px-2 py-1 rounded-full flex-shrink-0',
                  p.funded ? 'bg-gold/15 text-gold-dark' : 'bg-black/5 text-black/40',
                ]}>
                  {p.funded ? 'Funded' : 'Unfunded'}
                </span>
              </div>
              <p class="text-black/60 text-sm leading-relaxed flex-1 mb-4">{p.description}</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {p.need_tags.map(tag => (
                  <span class="text-[11px] bg-warm-surface border border-black/[0.08] text-black/50 px-2 py-0.5 rounded-full capitalize">
                    {tag.replace('_', ' ')}
                  </span>
                ))}
              </div>
              {p.website && !p.website.startsWith('#') ? (
                <a
                  href={p.website}
                  class="text-gold-dark text-sm font-500 no-underline hover:underline inline-flex items-center gap-1 mt-auto"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Visit website
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
              ) : (
                <span class="text-black/30 text-xs italic mt-auto">Website — TODO[CONFIRM]</span>
              )}
            </div>
          ))}
        </div>
      </div>

      <p id="no-results" class="hidden text-center text-black/50 py-12">No partners match this filter. <button data-filter="" class="filter-btn text-gold-dark underline">Show all →</button></p>
    </div>
  </section>

  <!-- Work with us -->
  <section class="section-warm section-padding py-12" aria-labelledby="work-with-us-heading">
    <div class="container-max max-w-3xl text-center">
      <h2 id="work-with-us-heading" class="font-heading font-700 text-brand-black heading-rule mb-4" style="--tw-heading-rule-width: auto;">
        Work with us
      </h2>
      <p class="text-black/60 mb-2 max-w-xl mx-auto">
        Are you an organisation that supports veterans? We are building a network of partners committed to No Wrong Door. If you would like to discuss a partnership, we would love to hear from you.
      </p>
      <p class="text-black/50 text-sm mb-8">
        We work with both funded and unfunded partners — what matters is that veterans receive the right support.
      </p>
      <a href="/contact" class="btn-primary px-8 py-4 rounded-lg font-600 inline-flex">Get in touch →</a>
    </div>
  </section>

</BaseLayout>

<script>
  // Client-side partner filter
  (function () {
    const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.partner-card');
    const noResults = document.getElementById('no-results');

    function filter(tag: string) {
      let visible = 0;
      cards.forEach(card => {
        const tags = card.dataset.tags ?? '';
        const match = !tag || tags.split(' ').includes(tag);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      noResults?.classList.toggle('hidden', visible > 0);

      btns.forEach(btn => {
        const active = btn.dataset.filter === tag;
        btn.setAttribute('aria-pressed', String(active));
        btn.className = [
          'filter-btn px-4 py-2 rounded-full text-sm font-500 border transition-all',
          active ? 'bg-gold border-gold text-brand-black' : 'border-black/20 text-black/70 hover:border-gold/50 bg-white',
        ].join(' ');
      });
    }

    btns.forEach(btn => {
      btn.addEventListener('click', () => filter(btn.dataset.filter ?? ''));
    });
  })();
</script>
