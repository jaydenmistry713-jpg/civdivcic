---
// Footer.astro — funding-grade footer, appears on every page via BaseLayout
// REQ-5.1
---

<footer class="bg-brand-black text-white" role="contentinfo">

  <!-- Newsletter row -->
  <div class="bg-black-800 border-b border-white/10">
    <div class="container-max px-4 md:px-8 py-10">
      <div class="max-w-2xl">
        <h2 class="font-heading font-700 text-xl text-white mb-1">Stay connected</h2>
        <p class="text-white/70 text-sm mb-4">Stories, updates and resources for veterans and supporters. Unsubscribe any time.</p>
        <!-- Netlify Forms newsletter — low-sensitivity only (name + email) -->
        <form
          name="newsletter"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="flex flex-col sm:flex-row gap-3"
          aria-label="Newsletter sign-up form"
        >
          <input type="hidden" name="form-name" value="newsletter" />
          <p class="hidden" aria-hidden="true"><label>Do not fill this in: <input name="bot-field" /></label></p>

          <div class="flex-1 min-w-0">
            <label for="newsletter-name" class="sr-only">Your first name</label>
            <input
              type="text"
              id="newsletter-name"
              name="name"
              placeholder="First name"
              autocomplete="given-name"
              required
              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-white/40 focus:border-gold focus:ring-2 focus:ring-gold/20 transition text-sm"
              style="min-height: 48px;"
            />
          </div>

          <div class="flex-[2] min-w-0">
            <label for="newsletter-email" class="sr-only">Your email address</label>
            <input
              type="email"
              id="newsletter-email"
              name="email"
              placeholder="Email address"
              autocomplete="email"
              required
              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-white/40 focus:border-gold focus:ring-2 focus:ring-gold/20 transition text-sm"
              style="min-height: 48px;"
            />
          </div>

          <button type="submit" class="btn-primary px-6 py-3 text-sm whitespace-nowrap rounded-lg">
            Sign up
          </button>
        </form>
        <p class="text-white/40 text-[11px] mt-2">
          This site is protected by reCAPTCHA.
          <a href="/policies#privacy" class="text-white/60 hover:text-white underline">Privacy Policy</a> ·
          <a href="/policies#terms" class="text-white/60 hover:text-white underline">Terms of Service</a> ·
          Your email will never be shared. <a href="/policies#privacy" class="text-white/60 hover:text-white underline">Privacy Notice</a>
        </p>
      </div>
    </div>
  </div>

  <!-- Main footer columns -->
  <div class="container-max px-4 md:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Column 1: Brand block -->
      <div>
        <a href="/" class="flex items-center gap-3 no-underline mb-4" aria-label="CivDivCIC home">
          <div class="w-9 h-9 rounded-full bg-gold flex items-center justify-center flex-shrink-0" aria-hidden="true">
            <span class="font-heading font-800 text-brand-black text-sm leading-none">CD</span>
          </div>
          <span class="font-heading font-700 text-white text-lg">CivDivCIC</span>
        </a>
        <p class="text-white/70 text-sm leading-relaxed mb-3">
          "No veteran should feel disconnected from support."
        </p>
        <p class="text-white/50 text-sm leading-relaxed">
          We operate a <strong class="text-white/70">No Wrong Door</strong> approach — connecting veterans and their families to the right support, the first time.
        </p>
        <p class="text-white/40 text-[11px] mt-4">
          Community Interest Company No. 13697459
        </p>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="font-heading font-600 text-gold-tint text-sm uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm" role="list">
          {[
            { label: 'Get Support',        href: '/support' },
            { label: 'Make a Referral',    href: '/referral' },
            { label: 'About Us',           href: '/about' },
            { label: 'Partnerships',       href: '/partnerships' },
            { label: 'Heritage & WASP',    href: '/heritage' },
            { label: 'Get Involved',       href: '/get-involved' },
            { label: 'News & Events',      href: '/news' },
            { label: 'Contact',            href: '/contact' },
            { label: 'Donate',             href: '/donate' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-gold no-underline hover:underline transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Governance & Safeguarding -->
      <div>
        <h3 class="font-heading font-600 text-gold-tint text-sm uppercase tracking-wider mb-4">Governance & Safeguarding</h3>
        <ul class="space-y-2 text-sm" role="list">
          {[
            { label: 'Governance & Accountability', href: '/policies#governance' },
            { label: 'Safeguarding Policy',         href: '/policies#safeguarding' },
            { label: 'Privacy Policy',              href: '/policies#privacy' },
            { label: 'IT & Data Protection',        href: '/policies#it-data' },
            { label: 'Equality & Inclusion',        href: '/policies#equality' },
            { label: 'Complaints Policy',           href: '/policies#complaints' },
            { label: 'Terms & Conditions',          href: '/policies#terms' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-gold no-underline hover:underline transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact & Access -->
      <div>
        <h3 class="font-heading font-600 text-gold-tint text-sm uppercase tracking-wider mb-4">Contact & Access</h3>
        <address class="not-italic text-white/70 text-sm space-y-3">
          <div class="flex gap-2">
            <!-- Location icon -->
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span>
              4th Floor, Silverstream House<br/>
              45 Fitzroy Street, Fitzrovia<br/>
              London W1T 6EB
            </span>
          </div>
          <div class="flex gap-2 items-start">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:admin@civdivcic.org.uk" class="text-white/70 hover:text-gold no-underline hover:underline break-all">admin@civdivcic.org.uk</a>
          </div>
          <div class="flex gap-2 items-start">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/>
            </svg>
            <span>Tel: <span class="text-white/50 italic">TODO[CONFIRM]</span></span>
          </div>
          <div class="flex gap-2 items-start">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>Open: <span class="text-white/50 italic">TODO[CONFIRM]</span></span>
          </div>
        </address>

        <!-- Social links -->
        <div class="flex gap-3 mt-6" aria-label="Social media links">
          {[
            { name: 'Facebook',  href: '#TODO[CONFIRM]', icon: 'M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z' },
            { name: 'LinkedIn',  href: '#TODO[CONFIRM]', icon: 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z M4 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z' },
            { name: 'X/Twitter', href: '#TODO[CONFIRM]', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
            { name: 'Instagram', href: '#TODO[CONFIRM]', icon: 'M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37zm1.5-4.87h.01M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2z' },
            { name: 'YouTube',   href: '#TODO[CONFIRM]', icon: 'M22.54 6.42a2.78 2.78 0 0 0-1.95-1.97C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.41 19.1C5.12 19.56 12 19.56 12 19.56s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z M9.75 15.02l5.75-3.27-5.75-3.27v6.54z' },
          ].map(s => (
            <a
              href={s.href}
              aria-label={`CivDivCIC on ${s.name}`}
              class="text-white/40 hover:text-gold transition-colors"
              rel="noopener noreferrer"
              target="_blank"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d={s.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Accreditation row -->
    <div class="mt-10 pt-8 border-t border-white/10">
      <p class="text-white/30 text-xs mb-3">
        Accreditations &amp; memberships — <em>TODO[CONFIRM]: only display marks actually held by the organisation</em>
      </p>
      <div class="flex flex-wrap gap-4 items-center">
        <!-- Placeholder for Armed Forces Covenant badge when confirmed -->
        <div class="border border-dashed border-white/20 rounded px-4 py-2 text-white/30 text-xs italic">
          Armed Forces Covenant badge — TODO[CONFIRM]
        </div>
      </div>
    </div>

    <!-- Legal line -->
    <div class="mt-8 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-white/40 text-[11px]">
        &copy; 2026 CivDivCIC &middot; Community Interest Company No. 13697459
      </p>
      <nav aria-label="Legal links" class="flex flex-wrap gap-x-4 gap-y-1">
        {[
          { label: 'Sitemap',       href: '/sitemap-index.xml' },
          { label: 'Accessibility', href: '/accessibility' },
          { label: 'Privacy',       href: '/policies#privacy' },
        ].map(l => (
          <a href={l.href} class="text-white/40 hover:text-white/70 text-[11px] no-underline hover:underline transition-colors">{l.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>
