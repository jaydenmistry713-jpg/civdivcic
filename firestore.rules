rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Referrals: all client access denied.
    // All reads and writes go exclusively through the Firebase Admin SDK
    // (called from the Netlify serverless function with service account credentials).
    match /referrals/{referralId} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
