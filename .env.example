# ---------------------------------------------------------------
# CivDivCIC Website — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------

# Firebase Admin SDK (server-side only — Netlify function)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Email notification (no personal data is sent in emails)
NOTIFICATION_EMAIL_TO=admin@civdivcic.org.uk
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# reCAPTCHA v3 (server-side secret)
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Public vars — exposed to browser (Astro PUBLIC_ prefix)
PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
PUBLIC_GA4_ID=G-XXXXXXXXXX
